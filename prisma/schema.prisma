generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JobApplication {
  id                 Int       @id @default(autoincrement())
  companyName        String?   @map("company_name") @db.VarChar(255)
  positionTitle      String?   @map("position_title") @db.VarChar(255)
  status             String?   @db.VarChar(20)
  remote             String?   @db.VarChar(10)
  applied            Boolean?  @default(false) @map("applied")
  notes              String?   @db.Text
  jobUrl             String?   @map("job_url") @db.VarChar(500)
  jobDescription     String?   @map("job_description") @db.Text
  recruiterName      String?   @map("recruiter_name") @db.VarChar(255)
  recruitingAgency   String?   @map("recruiting_agency") @db.VarChar(255)
  recruiterEmail     String?   @map("recruiter_email") @db.VarChar(255)
  recruiterPhone     String?   @map("recruiter_phone") @db.VarChar(50)
  recruiterLinkedin  String?   @map("recruiter_linkedin") @db.VarChar(500)
  dateAdded          DateTime  @default(now()) @map("date_added") @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("job_applications")
}

model DataEntry {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  companyInfo String   @map("company_info") @db.VarChar(255)
  url         String   @db.VarChar(500)
  industry    String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("data_entries")
}

model Person {
  id        Int      @id @default(autoincrement())
  firstName String   @map("first_name") @db.VarChar(255)
  lastName  String   @map("last_name") @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String   @db.VarChar(50)
  company   String   @db.VarChar(255)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("people")
}
