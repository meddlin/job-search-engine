generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model JobApplication {
  id                 Int       @id @default(autoincrement())
  companyName        String?   @map("company_name") @db.VarChar(255)
  positionTitle      String?   @map("position_title") @db.VarChar(255)
  status             String?   @db.VarChar(20)
  remote             String?   @db.VarChar(10)
  applied            Boolean?  @default(false) @map("applied")
  notes              String?   @db.Text
  jobUrl             String?   @map("job_url") @db.VarChar(500)
  jobDescription     String?   @map("job_description") @db.Text
  recruiterName      String?   @map("recruiter_name") @db.VarChar(255)
  recruitingAgency   String?   @map("recruiting_agency") @db.VarChar(255)
  recruiterEmail     String?   @map("recruiter_email") @db.VarChar(255)
  recruiterPhone     String?   @map("recruiter_phone") @db.VarChar(50)
  recruiterLinkedin  String?   @map("recruiter_linkedin") @db.VarChar(500)
  dateAdded          DateTime  @default(now()) @map("date_added") @db.Timestamp(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("job_applications")
}

model DataEntry {
  id          Int      @id @default(autoincrement())
  name        String   @db.VarChar(255)
  companyInfo String   @map("company_info") @db.VarChar(255)
  url         String   @db.VarChar(500)
  industry    String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("data_entries")
}

enum OsintScanStatus {
  queued
  running
  completed
  failed
}

enum OsintScanProgressStage {
  queued
  harvesting
  ingesting
  completed
  failed
}

model CompanyOsintScan {
  id              Int                    @id @default(autoincrement())
  companyName     String                 @map("company_name") @db.VarChar(255)
  domain          String                 @db.VarChar(255)
  sources         String[]               @default([])
  limit           Int                    @default(100)
  status          OsintScanStatus        @default(queued)
  progressStage   OsintScanProgressStage @default(queued) @map("progress_stage")
  heartbeatAt     DateTime?              @map("heartbeat_at") @db.Timestamp(6)
  startedAt       DateTime?              @map("started_at") @db.Timestamp(6)
  completedAt     DateTime?              @map("completed_at") @db.Timestamp(6)
  outputDirectory String?                @map("output_directory") @db.VarChar(1000)
  outputJsonPath  String?                @map("output_json_path") @db.VarChar(1000)
  outputXmlPath   String?                @map("output_xml_path") @db.VarChar(1000)
  hostCount       Int                    @default(0) @map("host_count")
  emailCount      Int                    @default(0) @map("email_count")
  ipCount         Int                    @default(0) @map("ip_count")
  urlCount        Int                    @default(0) @map("url_count")
  personCount     Int                    @default(0) @map("person_count")
  errorMessage    String?                @map("error_message") @db.Text
  rawResult       Json?                  @map("raw_result")
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamp(6)
  findings        CompanyOsintFinding[]

  @@index([domain])
  @@index([status])
  @@map("company_osint_scans")
}

model CompanyOsintFinding {
  id        Int              @id @default(autoincrement())
  scanId    Int              @map("scan_id")
  scan      CompanyOsintScan @relation(fields: [scanId], references: [id], onDelete: Cascade)
  type      String           @db.VarChar(50)
  value     String           @db.VarChar(1000)
  source    String?          @db.VarChar(255)
  metadata  Json?
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamp(6)

  @@unique([scanId, type, value])
  @@index([type])
  @@index([value])
  @@map("company_osint_findings")
}

model Person {
  id           Int      @id @default(autoincrement())
  firstName    String   @map("first_name") @db.VarChar(255)
  lastName     String   @map("last_name") @db.VarChar(255)
  email        String?  @db.VarChar(255)
  phone        String?  @db.VarChar(50)
  company      String?  @db.VarChar(255)
  notes        String?  @db.Text
  isRecruiter  Boolean  @default(false) @map("is_recruiter")
  linkedinUrl  String?  @map("linkedin_url") @db.VarChar(500)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamp(6)

  @@map("people")
}
